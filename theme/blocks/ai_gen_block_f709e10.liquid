{% doc %}
  @prompt
    Columns, can you remove the image section on the columns. Should only be text, I need a headline for the 3 columns
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-columns-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-columns-main-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.main_heading_spacing }}px;
    font-size: {{ block.settings.main_heading_size }}px;
    color: {{ block.settings.main_heading_color }};
    text-align: {{ block.settings.main_heading_alignment }};
  }

  .ai-columns-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
    width: 100%;
  }

  .ai-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.column_padding }}px;
    background-color: {{ block.settings.column_background }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-column-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-column-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-column-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
    align-self: {{ block.settings.button_alignment }};
  }

  .ai-column-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-columns-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-columns-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.main_heading != blank %}
    <h2 class="ai-columns-main-heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
  {% endif %}

  <div class="ai-columns-wrapper-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign heading_key = 'column_' | append: i | append: '_heading'
        assign text_key = 'column_' | append: i | append: '_text'
        assign button_text_key = 'column_' | append: i | append: '_button_text'
        assign button_link_key = 'column_' | append: i | append: '_button_link'

        assign column_heading = block.settings[heading_key]
        assign column_text = block.settings[text_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
      %}

      <div class="ai-column-{{ ai_gen_id }}">
        {% if column_heading != blank %}
          <h3 class="ai-column-heading-{{ ai_gen_id }}">{{ column_heading }}</h3>
        {% endif %}

        {% if column_text != blank %}
          <div class="ai-column-text-{{ ai_gen_id }}">{{ column_text }}</div>
        {% endif %}

        {% if button_text != blank and button_link != blank %}
          <a href="{{ button_link }}" class="ai-column-button-{{ ai_gen_id }}">
            {{ button_text }}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

