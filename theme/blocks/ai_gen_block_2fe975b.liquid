{% doc %}
  @prompt
    Write a short Danish message about free shipping over 399 DKK and fast delivery from Denmark, Write a short line about safe payment methods for Danish shoppers: “Secure payment with MobilePay and Dankort.” Translate to Danish.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-payment-banner__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-payment-banner__icon-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: 12px;
  }

  .ai-payment-banner__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-payment-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-payment-banner-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-payment-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-payment-banner__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-payment-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-payment-banner__content-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-payment-banner__icon-wrapper-{{ ai_gen_id }}">
        <svg class="ai-payment-banner__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
          <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
        <p class="ai-payment-banner__text-{{ ai_gen_id }}">
          {{ block.settings.message }}
        </p>
      </div>
    {% else %}
      <p class="ai-payment-banner__text-{{ ai_gen_id }}">
        {{ block.settings.message }}
      </p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Betalingsbesked",
  "settings": [
    {
      "type": "header",
      "content": "Indhold"
    },
    {
      "type": "inline_richtext",
      "id": "message",
      "label": "Besked",
      "default": "Sikker betaling med MobilePay og Dankort"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Vis betalingsikon",
      "default": true
    },
    {
      "type": "header",
      "content": "Farver"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Baggrund",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Ikon",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Tekstjustering",
      "options": [
        {
          "value": "left",
          "label": "Venstre"
        },
        {
          "value": "center",
          "label": "Centreret"
        },
        {
          "value": "right",
          "label": "Højre"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maksimal bredde",
      "min": 400,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Lodret polstring",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Vandret polstring",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Afstand mellem elementer",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typografi"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tekststørrelse",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Ikonstørrelse",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop bredde",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Betalingsbesked"
    }
  ],
  "tag": null
}
{% endschema %}
